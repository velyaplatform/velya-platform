{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Wazuh SIEM Server - Infrastructure and Application Monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Service Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Wazuh API",
      "type": "stat",
      "targets": [{ "expr": "wazuh_api_up", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Node Exporter",
      "type": "stat",
      "targets": [{ "expr": "up{job=\"wazuh-node\"}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "green", "text": "GREEN" }, "1": { "color": "yellow", "text": "YELLOW" }, "2": { "color": "red", "text": "RED" }, "3": { "color": "purple", "text": "UNKNOWN" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Indexer Status",
      "type": "stat",
      "targets": [{ "expr": "wazuh_indexer_cluster_status", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Active Shards",
      "type": "stat",
      "targets": [{ "expr": "wazuh_indexer_active_shards", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Unassigned Shards",
      "type": "stat",
      "targets": [{ "expr": "wazuh_indexer_unassigned_shards", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": {} },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Rules Loaded",
      "type": "stat",
      "targets": [{ "expr": "wazuh_rules_loaded", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Agents",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "active" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "disconnected" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "never_connected" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "pending" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "id": 10,
      "options": { "displayLabels": ["name", "value"], "legend": { "displayMode": "table", "placement": "bottom" }, "pieType": "donut", "reduceOptions": { "calcs": ["lastNotNull"] }, "tooltip": { "mode": "single" } },
      "title": "Agents by Status",
      "type": "piechart",
      "targets": [{ "expr": "wazuh_agents_total{status!=\"total\"}", "legendFormat": "{{ status }}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "pointSize": 5 } } },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 6 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Agents Over Time",
      "type": "timeseries",
      "targets": [
        { "expr": "wazuh_agents_total{status=\"active\"}", "legendFormat": "Active", "refId": "A" },
        { "expr": "wazuh_agents_total{status=\"disconnected\"}", "legendFormat": "Disconnected", "refId": "B" },
        { "expr": "wazuh_agents_total{status=\"total\"}", "legendFormat": "Total", "refId": "C" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "Events & Alerts",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 15 },
      "id": 20,
      "options": { "colorMode": "background_solid", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Total Events Processed",
      "type": "stat",
      "targets": [{ "expr": "wazuh_events_total", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 15 },
      "id": 21,
      "options": { "colorMode": "background_solid", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Total Alerts",
      "type": "stat",
      "targets": [{ "expr": "wazuh_alerts_total", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 15 },
      "id": 22,
      "options": { "colorMode": "background_solid", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Vulnerabilities Detected",
      "type": "stat",
      "targets": [{ "expr": "wazuh_vulnerabilities_total", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.9 }, { "color": "green", "value": 0.99 }] }, "min": 0, "max": 1 } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 15 },
      "id": 23,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "API Availability (5m)",
      "type": "stat",
      "targets": [{ "expr": "wazuh:api_availability:ratio_5m", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 103,
      "title": "System Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "continuous-GrYlRd" }, "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 30, "lineWidth": 2 }, "unit": "percent", "min": 0, "max": 100 } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 30,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "CPU Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\", job=\"wazuh-node\"}[5m])) * 100)", "legendFormat": "CPU Used %", "refId": "A" },
        { "expr": "avg by(instance) (rate(node_cpu_seconds_total{mode=\"iowait\", job=\"wazuh-node\"}[5m])) * 100", "legendFormat": "IO Wait %", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "continuous-GrYlRd" }, "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 30, "lineWidth": 2, "stacking": { "mode": "normal" } }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 31,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "title": "Memory Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "node_memory_MemTotal_bytes{job=\"wazuh-node\"} - node_memory_MemAvailable_bytes{job=\"wazuh-node\"}", "legendFormat": "Used", "refId": "A" },
        { "expr": "node_memory_Buffers_bytes{job=\"wazuh-node\"}", "legendFormat": "Buffers", "refId": "B" },
        { "expr": "node_memory_Cached_bytes{job=\"wazuh-node\"}", "legendFormat": "Cached", "refId": "C" },
        { "expr": "node_memory_MemAvailable_bytes{job=\"wazuh-node\"}", "legendFormat": "Available", "refId": "D" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "continuous-GrYlRd" }, "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.85 }] } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 32,
      "options": { "orientation": "horizontal", "displayMode": "gradient", "reduceOptions": { "calcs": ["lastNotNull"] }, "showUnfilled": true },
      "title": "Disk Usage",
      "type": "bargauge",
      "targets": [
        { "expr": "wazuh_data_disk_used_bytes / wazuh_data_disk_total_bytes", "legendFormat": "/var/ossec/data", "refId": "A" },
        { "expr": "1 - node_filesystem_avail_bytes{job=\"wazuh-node\", mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"wazuh-node\", mountpoint=\"/\"}", "legendFormat": "/ (root)", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "unit": "Bps" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "id": 33,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Network I/O",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{job=\"wazuh-node\", device!~\"lo|veth.*\"}[5m])", "legendFormat": "Receive {{ device }}", "refId": "A" },
        { "expr": "-rate(node_network_transmit_bytes_total{job=\"wazuh-node\", device!~\"lo|veth.*\"}[5m])", "legendFormat": "Transmit {{ device }}", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 104,
      "title": "Disk I/O",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "unit": "Bps" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "id": 40,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Disk Read/Write Throughput",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total{job=\"wazuh-node\"}[5m])", "legendFormat": "Read {{ device }}", "refId": "A" },
        { "expr": "-rate(node_disk_written_bytes_total{job=\"wazuh-node\"}[5m])", "legendFormat": "Write {{ device }}", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "axisBorderShow": false, "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "unit": "iops" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "id": 41,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Disk IOPS",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(node_disk_reads_completed_total{job=\"wazuh-node\"}[5m])", "legendFormat": "Reads {{ device }}", "refId": "A" },
        { "expr": "-rate(node_disk_writes_completed_total{job=\"wazuh-node\"}[5m])", "legendFormat": "Writes {{ device }}", "refId": "B" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["wazuh", "siem", "security", "infrastructure"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "America/Sao_Paulo",
  "title": "Wazuh Server Overview",
  "uid": "wazuh-server-overview",
  "version": 1
}
