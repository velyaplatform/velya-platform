{
  "name": "velya-platform",
  "version": "1.3.2",
  "private": true,
  "description": "Velya - AI-Native Hospital Operations Platform",
  "workspaces": [
    "apps/*",
    "services/*",
    "platform/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:integration": "turbo run test:integration",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml}\""
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^8.57.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.9.0"
}
